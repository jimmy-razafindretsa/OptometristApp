@page "/"
@using OptometristApp.Data
@inject DatabaseConnexionService DbService

<h1>Optometrist App Status</h1>

@if (_dbStatus == null)
{
    <p><em>Checking database connection...</em></p>
}
else
{
    <div class="alert @(_dbStatus == "Online" ? "alert-success" : "alert-danger")">
        Database is: <strong>@_dbStatus</strong>
    </div>

    <div class="mt-4">
        <a href="add-exam" class="btn btn-primary btn-lg">Add New Exam</a>
        <a href="add-patient" class="btn btn-success btn-lg ms-2">Add New Patient</a>
    </div>
}

@code {
    private string? _dbStatus;

    protected override async Task OnInitializedAsync()
    {
        // Call our async test method
        var isAlive = await DbService.IsConnectionHealthy();
        _dbStatus = isAlive ? "Online" : "Offline";
    }
}