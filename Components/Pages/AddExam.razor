@page "/add-exam"
@using OptometristApp.Data
@using OptometristApp.Data.Models
@using System.ComponentModel.DataAnnotations
@inject ExamService ExamService
@inject NavigationManager NavigationManager

<PageTitle>Add Exam</PageTitle>

<h1>Add a New Exam</h1>

<div class="row">
    <div class="col-md-6">
        <EditForm Model="@_examModel" OnValidSubmit="HandleValidSubmit" FormName="AddExamForm">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="mb-3">
                <label for="patient" class="form-label">Patient</label>
                <InputSelect id="patient" @bind-Value="_examModel.PatientId" class="form-select">
                    <option value="0">-- Select Patient --</option>
                    @if (_patients != null)
                    {
                        @foreach (var p in _patients)
                        {
                            <option value="@p.Id">@p.FullName (@p.Id)</option>
                        }
                    }
                </InputSelect>
                <ValidationMessage For="@(() => _examModel.PatientId)" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="examType" class="form-label">Exam Type</label>
                <InputSelect id="examType" @bind-Value="_examModel.ExamTypeId" class="form-select">
                    <option value="0">-- Select Exam Type --</option>
                    @if (_examTypes != null)
                    {
                        @foreach (var et in _examTypes)
                        {
                            <option value="@et.Id">@et.Nom</option>
                        }
                    }
                </InputSelect>
                <ValidationMessage For="@(() => _examModel.ExamTypeId)" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="dateExamen" class="form-label">Date</label>
                <InputDate id="dateExamen" @bind-Value="_examModel.DateExamen" class="form-control" />
                <ValidationMessage For="@(() => _examModel.DateExamen)" class="text-danger" />
            </div>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger">@_errorMessage</div>
            }

            <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">
                @if (_isSubmitting)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    <span> Saving...</span>
                }
                else
                {
                    <span>Save Exam</span>
                }
            </button>
            <a href="/" class="btn btn-secondary">Cancel</a>
        </EditForm>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private ExamFormModel _examModel { get; set; } = new();
    private List<Patient>? _patients;
    private List<ExamType>? _examTypes;
    private string? _errorMessage;
    private bool _isSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _patients = await ExamService.GetPatientsAsync();
            _examTypes = await ExamService.GetExamTypesAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading data: {ex.Message}";
        }
    }

    private async Task HandleValidSubmit()
    {
        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            var exam = new Exam
            {
                PatientId = _examModel.PatientId,
                ExamTypeId = _examModel.ExamTypeId,
                DateExamen = _examModel.DateExamen
            };

            await ExamService.AddExamAsync(exam);
            NavigationManager.NavigateTo("/");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error saving exam: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    public class ExamFormModel
    {
        [Required(ErrorMessage = "Please select a patient.")]
        [Range(1, int.MaxValue, ErrorMessage = "Please select a patient.")]
        public int PatientId { get; set; }

        [Required(ErrorMessage = "Please select an exam type.")]
        [Range(1, int.MaxValue, ErrorMessage = "Please select an exam type.")]
        public int ExamTypeId { get; set; }

        [Required(ErrorMessage = "Please select a date.")]
        public DateTime DateExamen { get; set; } = DateTime.Today;
    }
}
