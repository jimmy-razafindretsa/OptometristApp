@page "/doctor/{Id:int}"
@rendermode InteractiveServer
@using OptometristApp.Data.Models
@using OptometristApp.Data
@inject DoctorService DoctorService
@inject NavigationManager Navigation

<PageTitle>Doctor Details</PageTitle>

<div class="container mt-4">
    <button class="btn btn-outline-secondary mb-3" @onclick="GoBack">
        <i class="bi bi-arrow-left me-1"></i> Back
    </button>

    @if (_doctorDetail == null)
    {
        <div class="text-center my-5">
            <div class="spinner-border text-info" role="status"></div>
            <p class="mt-2 text-muted">Loading doctor details...</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Doctor Info -->
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 mb-4 h-100">
                    <div class="card-header bg-info text-white py-3">
                        <h3 class="mb-0"><i class="bi bi-person-badge-fill me-2"></i>@_doctorDetail.Doctor.NomComplet</h3>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="text-muted fw-bold small text-uppercase">Licence Number</label>
                            <p class="mb-0 fs-5"><code>@_doctorDetail.Doctor.Licence</code></p>
                        </div>
                        <div class="mb-3">
                            <label class="text-muted fw-bold small text-uppercase">Clinic</label>
                            <p class="mb-0 fs-5">
                                @if (_doctorDetail.Clinique != null)
                                {
                                    <i class="bi bi-hospital me-1 text-primary"></i>
                                    @_doctorDetail.Clinique.Nom
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">No clinic assigned</span>
                                }
                            </p>
                        </div>
                        
                        <div class="mt-4 p-3 bg-light rounded text-center">
                            <h2 class="text-info mb-0">@_doctorDetail.Patients.Count</h2>
                            <p class="text-muted small text-uppercase fw-bold mb-0">Assigned Patients</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Assigned Patients List -->
            <div class="col-lg-8">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="mb-0"><i class="bi bi-people-fill me-2"></i>Assigned Patients</h5>
                    </div>
                    <div class="card-body p-0">
                        @if (_doctorDetail.Patients.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-4">Patient Name</th>
                                            <th>Profession</th>
                                            <th>Email</th>
                                            <th class="text-end pe-4">File Created</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var patient in _doctorDetail.Patients)
                                        {
                                            <tr style="cursor:pointer;" @onclick="() => GoToPatient(patient.Id)">
                                                <td class="ps-4"><strong>@patient.FullName</strong></td>
                                                <td>@patient.Profession</td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(patient.Courriel))
                                                    {
                                                        <a href="mailto:@patient.Courriel" @onclick:stopPropagation>@patient.Courriel</a>
                                                    }
                                                </td>
                                                <td class="text-end pe-4 text-muted small">@patient.DateCreation.ToShortDateString()</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="p-5 text-center text-muted">
                                <i class="bi bi-person-x fs-1 d-block mb-3"></i>
                                <p class="mb-0">No patients are currently assigned to this doctor.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private DoctorDetailDto? _doctorDetail;

    protected override async Task OnInitializedAsync()
    {
        _doctorDetail = await DoctorService.GetDoctorDetailAsync(Id);
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/doctors-patients");
    }

    private void GoToPatient(int patientId)
    {
        Navigation.NavigateTo($"/patient/{patientId}");
    }
}
