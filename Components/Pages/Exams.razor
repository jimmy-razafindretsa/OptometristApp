@page "/exams"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@inject ExamService ExamService
@inject PatientService PatientService
@inject NavigationManager NavigationManager

<PageTitle>Manage Exams</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary"><i class="bi bi-calendar-check me-2"></i>Manage Exams</h1>
        <button class="btn btn-primary" @onclick="() => ShowForm()">
            <i class="bi bi-plus-circle me-1"></i> Add New Exam
        </button>
    </div>

    @if (_exams == null)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading exams...</span>
            </div>
        </div>
    }
    else if (!_exams.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i> No exams found. Click "Add New Exam" to create one.
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th @onclick='() => SortExams("Date")' style="cursor: pointer;" class="user-select-none">
                                    Date @if(_sortColumnExams == "Date") { <i class="bi @(_sortAscendingExams ? "bi-arrow-up" : "bi-arrow-down")"></i> }
                                </th>
                                <th>Patient</th>
                                <th @onclick='() => SortExams("Type")' style="cursor: pointer;" class="user-select-none">
                                    Exam Type @if(_sortColumnExams == "Type") { <i class="bi @(_sortAscendingExams ? "bi-arrow-up" : "bi-arrow-down")"></i> }
                                </th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var exam in SortedExams!)
                            {
                                    <tr>
                                        <td>@exam.DateExamen.ToShortDateString()</td>
                                        <td>
                                            <a href="#" @onclick="() => GoToPatient(exam.PatientId)" @onclick:preventDefault class="text-primary text-decoration-none fw-bold">
                                                @exam.PatientName
                                            </a>
                                        </td>
                                        <td><span class="badge bg-info text-dark">@exam.ExamTypeName</span></td>
                                    <td class="text-end">
                                        <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => ShowForm(exam)">
                                            <i class="bi bi-pencil"></i> Edit
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => ConfirmDelete(exam)">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@if (_showForm)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi @(_editingExam?.Id == 0 ? "bi-plus-circle" : "bi-pencil") me-2"></i>
                        @(_editingExam?.Id == 0 ? "Add New Exam" : "Edit Exam")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseForm"></button>
                </div>
                <EditForm Model="@_formModel" OnValidSubmit="SaveExam">
                    <div class="modal-body">
                        <DataAnnotationsValidator />
                        
                        <div class="mb-3">
                            <label class="form-label">Patient</label>
                            <InputSelect @bind-Value="_formModel.PatientId" class="form-select">
                                <option value="0">-- Select Patient --</option>
                                @if (_patients != null)
                                {
                                    @foreach (var p in _patients)
                                    {
                                        <option value="@p.Id">@p.FullName (@p.Id)</option>
                                    }
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => _formModel.PatientId)" class="text-danger" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Exam Type</label>
                            <InputSelect @bind-Value="_formModel.ExamTypeId" class="form-select">
                                <option value="0">-- Select Type --</option>
                                @if (_examTypes != null)
                                {
                                    @foreach (var et in _examTypes)
                                    {
                                        <option value="@et.Id">@et.Nom</option>
                                    }
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => _formModel.ExamTypeId)" class="text-danger" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Date</label>
                            <InputDate @bind-Value="_formModel.DateExamen" class="form-control" />
                            <ValidationMessage For="@(() => _formModel.DateExamen)" class="text-danger" />
                        </div>

                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <div class="alert alert-danger">@_errorMessage</div>
                        }
                    </div>
                    <div class="modal-footer bg-light">
                        <button type="button" class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">
                            @if (_isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            Save Exam
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@if (_showDeleteConfirm)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => _showDeleteConfirm = false"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this exam for <strong>@_deletingExam?.PatientName</strong> on <strong>@_deletingExam?.DateExamen.ToShortDateString()</strong>?</p>
                    <p class="text-danger small"><i class="bi bi-info-circle me-1"></i> This action cannot be undone.</p>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" @onclick="() => _showDeleteConfirm = false">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="DeleteExam" disabled="@_isSubmitting">
                        @if (_isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Exam>? _exams;
    private string _sortColumnExams = "Date";
    private bool _sortAscendingExams = false; // By default sort dates downwards (newest first)

    private IEnumerable<Exam>? SortedExams
    {
        get
        {
            if (_exams == null) return null;
            if (_sortColumnExams == "Date")
                return _sortAscendingExams ? _exams.OrderBy(e => e.DateExamen) : _exams.OrderByDescending(e => e.DateExamen);
            if (_sortColumnExams == "Type")
                return _sortAscendingExams ? _exams.OrderBy(e => e.ExamTypeName) : _exams.OrderByDescending(e => e.ExamTypeName);
            return _exams;
        }
    }

    private void SortExams(string column)
    {
        if (_sortColumnExams == column)
            _sortAscendingExams = !_sortAscendingExams;
        else
        {
            _sortColumnExams = column;
            _sortAscendingExams = true;
        }
    }

    private List<Patient>? _patients;
    private List<ExamType>? _examTypes;
    
    private bool _showForm = false;
    private bool _showDeleteConfirm = false;
    private bool _isSubmitting = false;
    private string? _errorMessage;
    
    private Exam? _editingExam;
    private Exam? _deletingExam;
    private ExamFormModel _formModel = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            _exams = await ExamService.GetExamsAsync();
            _patients = await PatientService.GetPatientsAsync();
            _examTypes = await ExamService.GetExamTypesAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading data: {ex.Message}";
        }
    }

    private void GoToPatient(int patientId)
    {
        NavigationManager.NavigateTo($"/patient/{patientId}");
    }

    private void ShowForm(Exam? exam = null)
    {
        _errorMessage = null;
        if (exam == null)
        {
            _editingExam = new Exam { Id = 0, DateExamen = DateTime.Today };
            _formModel = new ExamFormModel { DateExamen = DateTime.Today };
        }
        else
        {
            _editingExam = exam;
            _formModel = new ExamFormModel
            {
                PatientId = exam.PatientId,
                ExamTypeId = exam.ExamTypeId,
                DateExamen = exam.DateExamen
            };
        }
        _showForm = true;
    }

    private void CloseForm()
    {
        _showForm = false;
        _editingExam = null;
    }

    private async Task SaveExam()
    {
        if (_editingExam == null) return;
        
        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            var exam = new Exam
            {
                Id = _editingExam.Id,
                PatientId = _formModel.PatientId,
                ExamTypeId = _formModel.ExamTypeId,
                DateExamen = _formModel.DateExamen
            };

            if (exam.Id == 0)
                await ExamService.AddExamAsync(exam);
            else
                await ExamService.UpdateExamAsync(exam);

            await LoadData();
            CloseForm();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error saving: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void ConfirmDelete(Exam exam)
    {
        _deletingExam = exam;
        _showDeleteConfirm = true;
    }

    private async Task DeleteExam()
    {
        if (_deletingExam == null) return;
        
        _isSubmitting = true;
        try
        {
            await ExamService.DeleteExamAsync(_deletingExam.Id);
            await LoadData();
            _showDeleteConfirm = false;
            _deletingExam = null;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error deleting: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    public class ExamFormModel
    {
        [Required(ErrorMessage = "Please select a patient.")]
        [Range(1, int.MaxValue, ErrorMessage = "Please select a patient.")]
        public int PatientId { get; set; }

        [Required(ErrorMessage = "Please select an exam type.")]
        [Range(1, int.MaxValue, ErrorMessage = "Please select an exam type.")]
        public int ExamTypeId { get; set; }

        [Required(ErrorMessage = "Please select a date.")]
        public DateTime DateExamen { get; set; } = DateTime.Today;
    }
}
